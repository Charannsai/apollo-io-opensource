# OutReach AI - Environment Configuration

# Database
# Note: For local development with SQLite, you can use the default file path.
DATABASE_URL="file:../data/outreach.db"

# Gemini AI (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI (optional)
GROQ_API_KEY=your_groq_api_key_here

# Apify (for lead scraping tasks)
APIFY_API_KEY=your_apify_api_key_here

# Gmail OAuth (configure in Google Cloud Console for sending outreach emails)
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
